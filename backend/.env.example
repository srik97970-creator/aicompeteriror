# Express Server PORT Configuration
PORT=5000
JWT_SECRET=generate_a_long_cryptographically_secure_random_string_here

# PostgreSQL Database Connection URL (e.g., from Supabase, Render, or local Docker pg instance)
DATABASE_URL="postgresql://postgres:your_password@db.supabase.co:5432/postgres?schema=public"

# AI Integration Keys (Provide OpenAI for gpt-4o as requested, Gemini works as fallback)
OPENAI_API_KEY="your_openai_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"
