{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/_/backend/api/$1"
    }
  ],
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "index.js"
    }
  }
}
